# =============================================================================
# Thirty — Environment Variables
# =============================================================================
# Copier vers .env et remplir les valeurs

# Base de données
DATABASE_URL="postgresql://thirty:thirty@localhost:5432/thirty?schema=public"

# Better Auth
BETTER_AUTH_SECRET="change-me-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (optionnel, pour OAuth login)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# App
PORT=3000
NODE_ENV=development
