// =============================================================================
// Thirty - Prisma Schema (Prisma 7)
// Gut microbiome-focused food tracker
// =============================================================================
// Prisma 7 breaking changes applied:
// - provider "prisma-client" (Rust-free, ESM, native TS)
// - output required (generated into src/, not node_modules)
// - driver adapter required (PrismaPg) - configured in prisma.config.ts
// - prisma.config.ts for datasource URL (no longer in schema.prisma)
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URL configured in prisma.config.ts (Prisma 7)
  // url = env("DATABASE_URL") <- no longer used here
}

// =============================================================================
// ENUMS
// =============================================================================

enum FoodCategory {
  VEGETABLE        // vegetable
  FRUIT            // fruit
  LEGUME           // legume
  GRAIN            // grain
  NUT_SEED         // nut / seed
  HERB_SPICE       // herb / spice
  DAIRY            // dairy product (yogurt, milk, cream)
  CHEESE           // cheese (separate due to distinct microbiome profile)
  MEAT             // meat
  FISH             // fish / seafood
  EGG              // egg
  FERMENTED_CONDIMENT // miso, soy sauce, fish sauce, vinegar...
  BEVERAGE         // tea, coffee, kombucha, water kefir
  OTHER            // unclassifiable
}

enum PreparationMethod {
  RAW              // raw
  STEAMED          // steamed
  BOILED           // boiled
  ROASTED          // roasted / grilled
  FRIED            // fried
  FERMENTED        // fermented
  LACTOFERMENTED   // lacto-fermented
  SPROUTED         // sprouted
  SOAKED           // soaked
  DRIED            // dried
  AGED             // aged (cheeses)
  SMOKED           // smoked
}

enum MealMoment {
  BREAKFAST        // breakfast
  LUNCH            // lunch
  DINNER           // dinner
  SNACK            // snack
}

enum PortionSize {
  SMALL            // small
  MEDIUM           // medium
  LARGE            // large
}

enum SuggestionType {
  DIVERSITY        // plant diversity
  FERMENTED        // fermented foods
  PREPARATION      // preparation method
  SEASONAL         // seasonality
  POLYPHENOL       // polyphenols
  MUCOSAL_SUPPORT  // mucosal support (omega-3, collagen...)
  CHEESE           // aged vs industrial cheeses
}

enum Trend {
  IMPROVING
  STABLE
  DECLINING
}

// =============================================================================
// AUTH - Tables managed by Better Auth
// =============================================================================
// Better Auth creates and manages its own tables (user, session, account,
// verification). We do NOT redefine them here - the Better Auth Prisma
// adapter handles that.
//
// We extend the user profile via a separate UserProfile table linked to
// the Better Auth user by ID.
// =============================================================================

// =============================================================================
// USER PROFILE - Better Auth user extension
// =============================================================================

model UserProfile {
  id        String   @id @default(cuid())
  userId    String   @unique // FK to Better Auth user

  // Preferences
  displayName String?
  timezone    String   @default("Europe/Paris")
  locale      String   @default("fr")

  // Customizable goals
  weeklyPlantGoal  Int @default(30)  // plants/week goal (default 30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  mealEntries  MealEntry[]
  dailyScores  DailyScore[]

  @@map("user_profiles")
}

// =============================================================================
// FOOD - Curated food database
// =============================================================================

model Food {
  id        String       @id @default(cuid())

  // Identification
  nameFr    String       // French name (primary search key)
  nameEn    String?      // English name (optional)
  category  FoodCategory
  isPlant   Boolean      @default(false) // counts toward "30 plants"

  // Microbiome profile - base scores (0-5)
  solubleFiberScore    Float @default(0) // soluble fiber
  insolubleFiberScore  Float @default(0) // insoluble fiber
  prebioticScore       Float @default(0) // inulin, FOS, GOS, resistant starch
  polyphenolScore      Float @default(0) // polyphenols
  isFermented          Boolean @default(false)
  probioticsScore      Float @default(0) // live microorganism density
  omega3Score          Float @default(0) // omega-3
  mucosalSupportScore  Float @default(0) // collagen, glutamine, zinc

  // Metadata
  seasonMonths  Int[]    // [1-12], e.g. [9,10,11] for squash
  synonyms      String[] // e.g. ["courgette", "zucchini"]
  tags          String[] // e.g. ["rich in inulin", "omega-3 source"]
  sources       String[] // scoring bibliographic references

  // Available preparations for this food
  // (no "sprouted yogurt" or "aged parsley")
  availablePreparations PreparationMethod[]
  defaultPreparation    PreparationMethod @default(RAW)

  // Flag for user-added foods (not curated)
  isUserCreated Boolean @default(false)
  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  preparationModifiers PreparationModifier[]
  foodLogs             FoodLog[]

  // Search indexes
  @@index([nameFr])
  @@index([category])
  @@index([isPlant])
  @@map("foods")
}

// =============================================================================
// PREPARATION MODIFIER - Multiplier factors per preparation method
// =============================================================================
// ADR-005: hybrid system with multipliers + overrides
// Final score = base_score x factor + bonus
// Override replaces the base score when present (e.g. fermented foods)
// =============================================================================

model PreparationModifier {
  id      String            @id @default(cuid())
  foodId  String
  method  PreparationMethod

  // Multiplier factors (applied to Food base scores)
  fiberFactor      Float @default(1.0)  // 0.0 - 2.0
  prebioticFactor  Float @default(1.0)
  polyphenolFactor Float @default(1.0)
  probioticsFactor Float @default(1.0)
  microbiomeBonus  Float @default(0)    // -2 to +5

  // Optional override (ADR-005)
  // When present, replaces the base score instead of multiplying it
  // E.g. sauerkraut overrides probioticsScore to 4 because it's no longer
  // just "cabbage x a factor"
  overrideProfile  Json?  // Partial<MicrobiomeProfile> as JSONB

  // Relations
  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([foodId, method])
  @@map("preparation_modifiers")
}

// =============================================================================
// MEAL ENTRY - A meal (time of day)
// =============================================================================

model MealEntry {
  id            String     @id @default(cuid())
  userProfileId String
  date          DateTime   @db.Date // meal date (no time)
  moment        MealMoment
  note          String?    // optional free-text note ("at mom's", "Japanese restaurant")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  foodLogs    FoodLog[]

  @@index([userProfileId, date])
  @@index([date])
  @@map("meal_entries")
}

// =============================================================================
// FOOD LOG - A food logged in a meal
// =============================================================================

model FoodLog {
  id              String            @id @default(cuid())
  mealEntryId     String
  foodId          String
  preparationMethod PreparationMethod
  portionSize     PortionSize?      // optional (ADR: no mandatory gram tracking)

  // Score computed at log time (denormalized for performance)
  // Avoids recomputation if factors change
  computedScore   Json?             // { fiber, prebiotic, polyphenol, probiotics, omega3, mucosal, bonus }

  createdAt DateTime @default(now())

  // Relations
  mealEntry MealEntry @relation(fields: [mealEntryId], references: [id], onDelete: Cascade)
  food      Food      @relation(fields: [foodId], references: [id])

  @@index([mealEntryId])
  @@index([foodId])
  @@map("food_logs")
}

// =============================================================================
// DAILY SCORE - Daily microbiome score (denormalized)
// =============================================================================
// Computed/recomputed on each food log for the given date.
// Stored to avoid recomputing history on every display.
// =============================================================================

model DailyScore {
  id            String   @id @default(cuid())
  userProfileId String
  date          DateTime @db.Date

  // Overall score (0-100)
  totalScore    Float

  // Per-axis breakdown (0-100 each)
  diversityScore      Float // plant diversity (rolling week)
  fiberPrebioticScore Float
  fermentedScore      Float
  polyphenolScore     Float
  mucosalSupportScore Float
  preparationScore    Float

  // Diversity metrics (rolling week D-6 to D)
  rollingPlantCount      Int   // unique plants over 7 days
  rollingTotalFoodCount  Int   // unique foods over 7 days (all categories)
  trend                  Trend @default(STABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, date])
  @@index([userProfileId, date(sort: Desc)])
  @@map("daily_scores")
}

// =============================================================================
// SUGGESTION RULE - Contextual suggestion rules
// =============================================================================
// No ML - explicit business rules (ADR-002)
// Stored in DB to be editable without redeploying
// =============================================================================

model SuggestionRule {
  id              String         @id @default(cuid())
  type            SuggestionType

  // Trigger condition (structured JSON)
  // E.g. { "metric": "fermented_days_without", "operator": ">=", "value": 5 }
  condition       Json

  // Message template (with placeholders)
  // E.g. "It's been {days} days without fermented food. How about some {suggestion}?"
  messageFr       String
  messageEn       String?

  // Display control
  cooldownHours   Int    @default(24)  // don't re-show before X hours
  priority        Int    @default(50)  // 0-100, highest priority shown first
  isActive        Boolean @default(true)

  // Suggested foods (optional)
  suggestedFoodIds String[] // food IDs to suggest in the message

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  dismissals SuggestionDismissal[]

  @@map("suggestion_rules")
}

// =============================================================================
// SUGGESTION DISMISSAL - Tracking suggestions seen/dismissed per user
// =============================================================================

model SuggestionDismissal {
  id               String   @id @default(cuid())
  // FK to Better Auth user table (not managed by Prisma, no @relation possible).
  // Referential integrity enforced at application level.
  userId           String
  suggestionRuleId String
  dismissedAt      DateTime @default(now())

  // Relations
  suggestionRule SuggestionRule @relation(fields: [suggestionRuleId], references: [id], onDelete: Cascade)

  @@index([userId, suggestionRuleId])
  @@index([userId, dismissedAt(sort: Desc)])
  @@map("suggestion_dismissals")
}

// =============================================================================
// FAVORITE MEAL - Favorite meal templates for quick entry
// =============================================================================

model FavoriteMeal {
  id            String     @id @default(cuid())
  // FK to Better Auth user table (not managed by Prisma, no @relation possible).
  // Referential integrity enforced at application level.
  userId        String
  name          String     // "My usual breakfast"
  moment        MealMoment?

  // Favorite composition
  items         Json       // Array<{ foodId, preparationMethod, portionSize? }>

  usageCount    Int @default(0) // for sorting by usage frequency
  lastUsedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("favorite_meals")
}
