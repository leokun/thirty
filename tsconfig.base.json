// =============================================================================
// Thirty — Base tsconfig (TypeScript 6.0)
// =============================================================================
// TS 6.0 nouveaux defaults appliqués :
// - module: "esnext" (défaut TS6, ESM dominant)
// - moduleResolution: "bundler" (implicite avec module preserve/esnext)
// - target: "es2023" (runtimes evergreen)
// - strict: true (défaut TS6)
// - ESM natif (package.json "type": "module")
//
// TS 6.0 est le pont vers TS 7.0 (Go-based) — on prépare la migration
// en évitant les features dépréciées (import assertions, outFile, AMD/UMD)
// =============================================================================
{
  "compilerOptions": {
    // TS 6.0 defaults — explicités pour clarté
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,

    // Sortie
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // Rigueur additionnelle
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,

    // Résolution
    "resolveJsonModule": true,
    "skipLibCheck": true,

    // Prépare TS 7.0 — flag de compatibilité
    // Permet de comparer le comportement TS6 vs TS7 (Go-based)
    // "stableTypeOrdering": true,

    // Lib
    "lib": ["ES2023", "DOM", "DOM.Iterable"]
  },
  "exclude": ["node_modules", "dist"]
}
